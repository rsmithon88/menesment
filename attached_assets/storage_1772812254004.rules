rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Profile Pictures
    match /profile_pictures/{userId}/{allPaths=**} {
      // Anyone can read profile pictures
      allow read; 
      // Only the authenticated owner can write
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Student Photos for Admit Cards
    match /student_photos/{studentId}/{allPaths=**} {
      // Anyone can read student photos
      allow read;
      // Any authenticated user (admin/teacher) can write
      allow write: if request.auth != null;
    }
    
    // Signatures for Admit Cards
    match /signatures/{allPaths=**} {
      // Anyone can read signatures
      allow read;
      // Any authenticated user can write (UI restricts to admin)
      allow write: if request.auth != null;
    }

  }
}
